# 1. Copy this file and rename the copy to ".env"
# 2. Paste your real values after the "=" signs
# 3. NEVER share .env or commit it to GitHub (.gitignore already blocks it)

# Your YouTube Data API key (from Google Cloud Console).
# Used for reading PUBLIC stats of any channel/video, including your own.
YOUTUBE_API_KEY=paste_your_api_key_here

# Your own channel ID (starts with "UC...").
# Find it at: https://www.youtube.com/account_advanced
MY_CHANNEL_ID=paste_your_channel_id_here
